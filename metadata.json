{
  "name": "package_manager",
  "version": "1.0.0",
  "description": "Plugin manager for the Logos system",
  "author": "Logos Core Team",
  "type": "core",
  "interface": "universal",
  "category": "management",
  "main": "package_manager_plugin",
  "dependencies": [],
  "include": [],
  "capabilities": ["plugin_installation"],

  "nix": {
    "packages": {
      "runtime": ["nlohmann_json"]
